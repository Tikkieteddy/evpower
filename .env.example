# Google service account credentials.
# Recommended on Vercel: paste base64 of the full JSON key.
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Alternative local format: raw JSON string from the service account key.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Alternative split format if you do not want to paste full JSON.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Provided production resources. Keep these unless the target Sheet/Drive changes.
GOOGLE_SHEET_ID=1lfT2mjo1HahuJmmtjVI7yqWGpVprSGjxo7Hnc9M-6vU
GOOGLE_SHEET_NAME=Sheet1
GOOGLE_DRIVE_FOLDER_ID=1Zfyw75eTEgX8Gnckml8zvOPS96B86swo

# Optional, recommended for Drive uploads.
# Service accounts cannot own files in normal My Drive storage.
# Deploy the Apps Script in README and paste its Web App URL here.
GOOGLE_APPS_SCRIPT_UPLOAD_URL=

# GitHub storage. If these are set, profile data is stored in GitHub instead of Google Sheet,
# and image upload also uses GitHub.
# The target repository should be public if admins need to open picture links directly.
GITHUB_UPLOAD_TOKEN=
GITHUB_UPLOAD_OWNER=
GITHUB_UPLOAD_REPO=
GITHUB_UPLOAD_BRANCH=main
GITHUB_UPLOAD_DIR=profile-images
GITHUB_DATA_PATH=data/profiles.json

# Simple admin login password.
ADMIN_PASSWORD=
SUPERVISOR_APPROVAL_SECRET=

# SMTP email settings for Verify notification emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional local-only preview mode. Set true to preview admin/track pages
# without Google credentials. Do not enable in production.
USE_MOCK_GOOGLE=false
